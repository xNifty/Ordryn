DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=dbname
SESSION_KEY=32characterormorestring
PORT=8080
BASE_PATH=/ (path prefix when served under a subpath, e.g. /gotodo; not a full URL)
USE_HTTPS=false (force https in calendar subscribe URLs when behind proxy without X-Forwarded-Proto)
MAILGUN_API_KEY=your-mailgun-api-key-here
MAILGUN_DOMAIN=your-mailgun-domain-here
REDIS_URL=your-redis-url-here