# Required — server will not start if .env is missing or these are empty
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=dbname
SESSION_KEY=32characterormorestring
REDIS_URL=redis://localhost:6379/0

# Optional (defaults shown)
PORT=8080
GOTODO_MODE=full
BASE_PATH=/
USE_HTTPS=false

# Optional email
MAILGUN_API_KEY=your-mailgun-api-key-here
MAILGUN_DOMAIN=your-mailgun-domain-here
FROM_EMAIL=no-reply@example.com

# Optional first-boot bootstrap (idempotent; safe to leave set)
# GOTODO_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# GOTODO_BOOTSTRAP_ADMIN_PASSWORD=change-me
# GOTODO_BOOTSTRAP_ENABLE_API=true
# GOTODO_BOOTSTRAP_CREATE_API_KEY=true

# Optional site branding (env wins over config/config.json when set)
# SITE_NAME=GoTodo
# SITE_VERSION=v0.0.0
# DEFAULT_TIMEZONE=America/New_York
# SHOW_CHANGELOG=true
# ASSET_VERSION=20251130

# Alternate Redis (if REDIS_URL is unset)
# REDIS_ADDR=localhost:6379
# REDIS_PASSWORD=
